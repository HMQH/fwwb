DATABASE_URL=postgresql+psycopg://postgres:你的密码@127.0.0.1:5432/antifraud
JWT_SECRET=请改为足够长的随机字符串

# 可选：上传目录。不设则默认指向仓库根目录下的 storage/uploads
# UPLOAD_ROOT=G:/Document/contest/fwwb/Code/storage/uploads
# 可选：单文件最大字节数（默认 52428800）
# MAX_UPLOAD_BYTES=52428800

# 可选：语音深度分析（默认沿用 DETECTION_LLM_* 的接口地址 / Key）
# AUDIO_SCAM_INSIGHT_MODEL=qwen3.5-omni-plus
# AUDIO_SCAM_INSIGHT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AUDIO_SCAM_INSIGHT_API_KEY=你的密钥
# AUDIO_SCAM_INSIGHT_TIMEOUT_SECONDS=180
# AUDIO_SCAM_INSIGHT_MAX_FILE_BYTES=9500000
