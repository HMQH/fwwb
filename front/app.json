{
  "expo": {
    "name": "智獴反诈",
    "slug": "zhimeng-antifraud",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/zhimeng-antifraud-icon.png",
    "scheme": "zhimengantifraud",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/zhimeng-antifraud-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_CONTACTS",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "package": "com.zhimeng.antifraud"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/zhimeng-antifraud-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/zhimeng-antifraud-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "defaultChannel": "guardian-risk-alerts",
          "color": "#2F70E6"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "用于从相册选择截图或图片，以便提交反诈检测。"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
